BIN_EVAL_GARAGE_ENDPOINT=http://127.0.0.1:3900
BIN_EVAL_GARAGE_ACCESS_KEY=GK0123456789abcdef0123456789abcdef
BIN_EVAL_GARAGE_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BIN_EVAL_ARTIFACT_BUCKET=bin-eval-artifacts

BIN_EVAL_LLM_BASE_URL=http://127.0.0.1:4000
