BIN_EVAL_ENV=local

BIN_EVAL_POSTGRES_USER=bin_eval
BIN_EVAL_POSTGRES_PASSWORD=bin_eval
BIN_EVAL_POSTGRES_DB=bin_eval
BIN_EVAL_POSTGRES_PORT=55432
BIN_EVAL_DATABASE_URL=postgres://bin_eval:bin_eval@127.0.0.1:55432/bin_eval?sslmode=disable

BIN_EVAL_TEMPORAL_ADDRESS=127.0.0.1:7233
